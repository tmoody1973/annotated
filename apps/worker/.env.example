# Convex
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Deepgram (podcast transcription)
DEEPGRAM_API_KEY=

# Spotify (podcast metadata only — falls back to RSS for audio)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API (metadata)
YOUTUBE_API_KEY=

# Podcast Index (RSS feed lookup fallback)
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Worker auth (shared with Convex)
WORKER_AUTH_TOKEN=

# Worker listen port (defaults to 8080)
PORT=8080
