{
  "name": "extension",
  "displayName": "Annotated",
  "version": "0.1.0",
  "description": "Clip and annotate media from any web page — YouTube, podcasts, articles.",
  "author": "Tarik Moody <tarik@radiomilwaukee.org>",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@annotated/shared": "workspace:*",
    "@clerk/chrome-extension": "^3.1.30",
    "@heroui/react": "^3.0.5",
    "@heroui/styles": "^3.0.5",
    "convex": "^1.39.1",
    "plasmo": "^0.90.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/node": "^20.12.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "manifest": {
    "key": "$CRX_PUBLIC_KEY",
    "host_permissions": [
      "https://*/*"
    ],
    "permissions": [
      "sidePanel",
      "storage",
      "activeTab",
      "scripting",
      "cookies"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
