# Plasmo prefixes public env vars with PLASMO_PUBLIC_
PLASMO_PUBLIC_CONVEX_URL=
PLASMO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Step 5d clip/publish (dev). The worker token is bundled — DEV ONLY; production
# must route the publish through a Convex action so the secret stays server-side.
PLASMO_PUBLIC_WORKER_URL=http://localhost:8080
PLASMO_PUBLIC_WORKER_TOKEN=   # same value as the worker's WORKER_AUTH_TOKEN
PLASMO_PUBLIC_WEB_URL=http://localhost:3000
